{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(ant:*)",
      "Bash(make:*)",
      "Bash(java:*)",
      "Bash(javac:*)",
      "Bash(jar:*)",
      "Bash(scripts/*.sh:*)",
      "Bash(./scripts/*.sh:*)",
      "Bash(sqlite3:*)",
      "Bash(mysql:*)",
      "Bash(docker compose:*)",
      "Bash(docker-compose:*)",
      "Bash(docker ps:*)",
      "Bash(docker logs:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git stash list:*)",
      "Bash(git remote -v)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(tree:*)",
      "Bash(pwd)",
      "Bash(which:*)",
      "Bash(printenv:*)",
      "Bash(env)"
    ],
    "deny": [
      "Edit(upstream/openrsc-snapshot/**)",
      "Write(upstream/openrsc-snapshot/**)",
      "Edit(server/avatars/**)",
      "Edit(server/logs/**)",
      "Edit(server/inc/sqlite/*.db)",
      "Edit(server/inc/databases/**)",
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)"
    ]
  }
}

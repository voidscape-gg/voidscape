# Local MariaDB/Docker development only. Copy this file to .env and replace
# both passwords before exposing the database beyond a disposable workstation.
MARIADB_ROOT_USER=root
MARIADB_ROOT_PASSWORD=change-me-local-root-password
MARIADB_USER=openrsc
MARIADB_PASS=change-me-local-user-password
MYSQL_DUMPS_DIR=Backups

# ----------------------------------------------------------------------------
# voidscape additions (everything below is voidscape-specific, not from upstream)
# ----------------------------------------------------------------------------

# Frozen reference copy of upstream OpenRSC. 268MB. Recreate locally via:
#   scripts/fetch-upstream-snapshot.sh
# The vendored SHA is recorded in docs/DIVERGENCE.md.
upstream/openrsc-snapshot/

# Per-user Claude Code overrides (project-level settings.json IS tracked)
.claude/settings.local.json

# macOS noise (upstream had `\.DS_Store` which doesn't match — this does)
.DS_Store
**/.DS_Store

# Local override env (.env itself stays tracked with scaffold defaults)
.env.local
.env.*.local

# Voidscape build/run artifacts
/tmp-build/
/run-state/
dist/
PC_Launcher/src/main/resources/voidscape-launcher.properties

# Runtime SQLite databases (schema source lives in server/database/sqlite/)
server/inc/sqlite/*.db
server/inc/sqlite/*.db-journal
server/inc/sqlite/*.db-shm
server/inc/sqlite/*.db-wal

# Runtime minigame leaderboards
server/conf/server/data/pk_catching_sim_highscores.properties

# Per-developer client cache config (ip + port are written by scripts/run-client.sh)
Client_Base/Cache/ip.txt
Client_Base/Cache/port.txt
Client_Base/Cache/hideIp.txt

# Local scratch/output from captures, generated concepts, temporary extraction work, and bots
output/
tmp/

# Claude Code per-session skills (workflow scaffolding, not project content)
.claude/skills/

# rsc-mapgen working dir — restaged from server/.../maps on each render
tools/rsc-mapgen/input/
tools/rsc-mapgen/map.png

# voidscape: sprite/landscape packer scratch files
*.orsc.bak
*.orsc.new
*.orsc.predungeon


<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape>
            <solid android:color="#3A3430" />
            <stroke
                android:width="1dp"
                android:color="#5B5550" />
            <corners android:radius="4dp" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape>
            <gradient
                android:angle="270"
                android:endColor="#B6852E"
                android:startColor="#F5D77B" />
            <stroke
                android:width="1dp"
                android:color="#FFF0A8" />
            <corners android:radius="4dp" />
        </shape>
    </item>
    <item>
        <shape>
            <gradient
                android:angle="270"
                android:endColor="@color/voidscape_gold_dark"
                android:startColor="@color/voidscape_gold" />
            <stroke
                android:width="1dp"
                android:color="#FFE89C" />
            <corners android:radius="4dp" />
        </shape>
    </item>
</selector>

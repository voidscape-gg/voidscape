<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape>
            <solid android:color="#121820" />
            <stroke
                android:width="1dp"
                android:color="@color/voidscape_panel_border" />
            <corners android:radius="4dp" />
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <clip>
            <shape>
                <gradient
                    android:angle="0"
                    android:endColor="#FFE08A"
                    android:startColor="@color/voidscape_gold_dark" />
                <corners android:radius="4dp" />
            </shape>
        </clip>
    </item>
</layer-list>

<resources>

    <style name="VoidscapeLaunchTheme" parent="@android:style/Theme.NoTitleBar.Fullscreen">
        <item name="android:fontFamily">@font/exoregular</item>
        <item name="android:windowBackground">@drawable/voidscape_launch_background</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:colorAccent">@color/voidscape_gold</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/voidscape_splash_icon</item>
        <item name="android:windowSplashScreenBackground">@color/black</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@color/black</item>
    </style>

</resources>

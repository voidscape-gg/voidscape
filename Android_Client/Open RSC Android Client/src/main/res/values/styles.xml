<resources>

    <!--
        Base application theme, dependent on API level. This theme is replaced
        by AppBaseTheme from res/values-vXX/styles.xml on newer devices.
    -->
    <style name="AppBaseTheme" parent="android:Theme.Black">
        <!--
            Theme customizations available in newer API levels can go in
            res/values-vXX/styles.xml, while customizations related to
            backward-compatibility can go here.
        -->
    </style>

    <!-- Application theme. -->
    <style name="AppTheme" parent="AppBaseTheme">
        <!-- All customizations that are NOT specific to a particular API-level can go here. -->
    </style>

    <style name="VoidscapeLaunchTheme" parent="@android:style/Theme.NoTitleBar.Fullscreen">
        <item name="android:fontFamily">@font/exoregular</item>
        <item name="android:windowBackground">@drawable/voidscape_launch_background</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:colorAccent">@color/voidscape_gold</item>
    </style>

    <style name="VoidscapeDialogTheme" parent="@android:style/Theme.Material.Dialog.Alert">
        <item name="android:fontFamily">@font/exoregular</item>
        <item name="android:colorAccent">@color/voidscape_gold</item>
        <item name="android:windowBackground">@drawable/voidscape_dialog_background</item>
        <item name="android:textColorPrimary">@color/voidscape_text</item>
        <item name="android:textColorSecondary">@color/voidscape_muted</item>
        <item name="android:windowMinWidthMajor">72%</item>
        <item name="android:windowMinWidthMinor">72%</item>
    </style>

</resources>

[Unit]
Description=Voidscape native game account to portal account backfill sweep
After=voidscape-portal.service
Wants=voidscape-portal.service

[Service]
Type=oneshot
WorkingDirectory=/opt/voidscape
EnvironmentFile=/etc/voidscape/portal.env
ExecStart=/opt/voidscape/scripts/native-portal-backfill-sweep.sh
